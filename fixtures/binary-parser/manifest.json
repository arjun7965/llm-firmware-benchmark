{
  "schemaVersion": "1.0",
  "taskId": "binary-parser",
  "targetProfile": "portable-c11",
  "status": "scaffold",
  "language": "c11",
  "answer": {
    "format": "markdown-fenced-code",
    "language": "c",
    "output": "generated/answer.c"
  },
  "paths": {
    "starter": "starter",
    "mocks": "mocks",
    "publicTests": "tests/public",
    "reference": "reference",
    "scripts": "scripts",
    "generated": "generated",
    "build": "build"
  },
  "commands": [
    {
      "id": "host-compile",
      "phase": "compile",
      "argv": [
        "cc",
        "-std=c11",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-pedantic",
        "-Istarter",
        "generated/answer.c",
        "tests/public/test_binary_parser.c",
        "-o",
        "build/public-tests"
      ],
      "requiredTools": ["cc"],
      "timeoutMs": 30000
    }
  ]
}
