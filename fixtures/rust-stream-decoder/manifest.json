{
  "schemaVersion": "1.4",
  "taskId": "rust-stream-decoder",
  "targetProfile": null,
  "validationProfile": "stable-rust",
  "status": "active",
  "language": "rust",
  "toolVersionArgs": {
    "cargo": ["--version"],
    "cc": ["--version"],
    "rustc": ["--version"]
  },
  "answer": {
    "format": "markdown-fenced-code",
    "language": "rust",
    "output": "generated/answer.rs"
  },
  "paths": {
    "starter": "starter",
    "mocks": "mocks",
    "publicTests": "tests/public",
    "reference": "reference",
    "scripts": "scripts",
    "generated": "generated",
    "build": "build"
  },
  "commands": [
    {
      "id": "rust-test-compile",
      "phase": "compile",
      "argv": [
        "rustc",
        "--edition=2021",
        "--test",
        "starter/test_harness.rs",
        "-D",
        "warnings",
        "-o",
        "build/candidate-tests"
      ],
      "requiredTools": ["cargo", "cc", "rustc"],
      "timeoutMs": 30000
    },
    {
      "id": "rust-supervisor-compile",
      "phase": "compile",
      "argv": [
        "rustc",
        "--edition=2021",
        "starter/test_supervisor.rs",
        "-D",
        "warnings",
        "-o",
        "build/public-tests"
      ],
      "requiredTools": ["rustc"],
      "timeoutMs": 30000
    },
    {
      "id": "public-tests",
      "phase": "test",
      "argv": ["build/public-tests"],
      "requiredTools": [],
      "timeoutMs": 15000
    }
  ]
}
