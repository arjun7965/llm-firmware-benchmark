{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arjun7965/llm-coding-benchmark/schemas/repeat-scores.schema.json",
  "title": "Repeated benchmark scores",
  "type": "object",
  "required": ["rubric", "tasks"],
  "properties": {
    "rubric": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    }
  },
  "patternProperties": {
    "^(?!rubric$|tasks$)[a-z0-9]+(?:[._-][a-z0-9]+)*$": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^run[1-9][0-9]*$"
      },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        }
      }
    }
  },
  "additionalProperties": false
}
