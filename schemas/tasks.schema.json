{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arjun7965/llm-firmware-benchmark/schemas/tasks.schema.json",
  "title": "Benchmark task definitions",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "category",
      "suite",
      "validationProfile",
      "prompt"
    ],
    "allOf": [
      {
        "if": {
          "properties": {
            "suite": { "const": "firmware" }
          },
          "required": ["suite"]
        },
        "then": {
          "required": ["targetProfile"]
        }
      },
      {
        "if": {
          "required": ["targetProfile"]
        },
        "then": {
          "properties": {
            "suite": { "const": "firmware" }
          }
        }
      },
      {
        "if": {
          "properties": {
            "category": {
              "enum": ["embedded", "firmware"]
            }
          },
          "required": ["category"]
        },
        "then": {
          "properties": {
            "suite": { "const": "firmware" }
          }
        }
      }
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "category": {
        "type": "string",
        "minLength": 1
      },
      "suite": {
        "enum": ["firmware", "auxiliary"]
      },
      "validationProfile": {
        "enum": [
          "c11-host",
          "go-std",
          "node-typescript",
          "node-typescript-postgresql",
          "postgresql",
          "python3-pytest-hypothesis",
          "python3-stdlib",
          "react18-typescript",
          "stable-rust"
        ]
      },
      "prompt": {
        "type": "string",
        "minLength": 1
      },
      "targetProfile": {
        "type": "string",
        "enum": [
          "portable-c11",
          "c11-lock-free-spsc",
          "c11-mocked-hal",
          "armv7m-bare-metal",
          "rv32-bare-metal",
          "generic-rtos",
          "embedded-linux-posix"
        ]
      }
    }
  }
}
