{
  "schemaVersion": "1.3",
  "source": "reference/interrupt_vector.c",
  "mutations": [
    {
      "id": "accept-unaligned-stack-pointer",
      "description": "Accept an initial stack pointer that violates the Cortex-M eight-byte alignment rule.",
      "find": "(initial_stack_pointer & (INTERRUPT_VECTOR_STACK_ALIGNMENT - 1u)) == 0u",
      "replace": "true"
    },
    {
      "id": "accept-even-handler-address",
      "description": "Accept an ARM-state/even handler address without the required Thumb bit.",
      "find": "(handler & INTERRUPT_VECTOR_HANDLER_THUMB_BIT) != 0u",
      "replace": "true"
    },
    {
      "id": "accept-unaligned-vector-table-base",
      "description": "Program VTOR from a linker address that does not meet the 128-byte alignment requirement.",
      "find": "base_address % INTERRUPT_VECTOR_ALIGNMENT != 0u",
      "replace": "false"
    },
    {
      "id": "leave-external-irqs-enabled-during-relocation",
      "description": "Relocate the vector table without disabling external IRQs first.",
      "find": "nvic_write_icer(nvic, INTERRUPT_VECTOR_EXTERNAL_MASK);",
      "replace": "nvic_write_icer(nvic, 0u);"
    },
    {
      "id": "leave-stale-pending-irqs-at-startup",
      "description": "Retain pending IRQ state while installing the startup vector table.",
      "find": "nvic_write_icpr(nvic, INTERRUPT_VECTOR_EXTERNAL_MASK);",
      "replace": "nvic_write_icpr(nvic, 0u);"
    },
    {
      "id": "omit-last-default-vector-entry",
      "description": "Leave the highest external IRQ vector at its prior value.",
      "find": "index < INTERRUPT_VECTOR_ENTRY_COUNT;",
      "replace": "index < INTERRUPT_VECTOR_ENTRY_COUNT - 1u;"
    },
    {
      "id": "publish-vtor-before-table-barrier",
      "description": "Write VTOR before synchronizing the completed RAM vector table.",
      "find": "  interrupt_vector_sync_barrier();\n  scb_write_vtor(scb, base_address);",
      "replace": "  scb_write_vtor(scb, base_address);\n  interrupt_vector_sync_barrier();"
    },
    {
      "id": "skip-runtime-install-critical-section",
      "description": "Update a live vector table without masking interrupts.",
      "find": "const uint32_t interrupt_state = interrupt_vector_irq_save_disable();\n  interrupt_vector_write_entry(",
      "replace": "const uint32_t interrupt_state = UINT32_C(1);\n  interrupt_vector_write_entry("
    },
    {
      "id": "install-next-irq-slot",
      "description": "Install each handler into the following external IRQ slot.",
      "find": "INTERRUPT_VECTOR_CORE_ENTRY_COUNT + irq_number,",
      "replace": "INTERRUPT_VECTOR_CORE_ENTRY_COUNT + irq_number + 1u,"
    },
    {
      "id": "omit-runtime-install-barrier",
      "description": "Return from a live vector update without synchronizing the new handler entry.",
      "find": "    handler\n  );\n  interrupt_vector_sync_barrier();\n  interrupt_vector_irq_restore(interrupt_state);",
      "replace": "    handler\n  );\n  interrupt_vector_irq_restore(interrupt_state);"
    },
    {
      "id": "enable-before-clearing-pending",
      "description": "Unmask an IRQ before clearing its stale pending bit.",
      "find": "  nvic_write_icpr(state->nvic, irq_bit);\n  nvic_write_iser(state->nvic, irq_bit);",
      "replace": "  nvic_write_iser(state->nvic, irq_bit);\n  nvic_write_icpr(state->nvic, irq_bit);"
    },
    {
      "id": "enable-wrong-irq-bit",
      "description": "Use the neighboring NVIC bit rather than the requested IRQ number.",
      "find": "const uint32_t irq_bit = UINT32_C(1) << irq_number;",
      "replace": "const uint32_t irq_bit = UINT32_C(1) << (irq_number + 1u);"
    },
    {
      "id": "restore-runtime-interrupts-as-enabled",
      "description": "Lose a caller's disabled interrupt state after enabling an IRQ.",
      "find": "  nvic_write_iser(state->nvic, irq_bit);\n  interrupt_vector_irq_restore(interrupt_state);",
      "replace": "  nvic_write_iser(state->nvic, irq_bit);\n  interrupt_vector_irq_restore(interrupt_state | UINT32_C(1));"
    }
  ]
}
