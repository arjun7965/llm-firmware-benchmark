{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arjun7965/llm-firmware-benchmark/schemas/tasks.schema.json",
  "title": "Benchmark task definitions",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "category", "prompt"],
    "allOf": [
      {
        "if": {
          "properties": {
            "category": {
              "enum": ["embedded", "firmware"]
            }
          },
          "required": ["category"]
        },
        "then": {
          "required": ["targetProfile"]
        }
      }
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "category": {
        "type": "string",
        "minLength": 1
      },
      "prompt": {
        "type": "string",
        "minLength": 1
      },
      "targetProfile": {
        "type": "string",
        "enum": [
          "portable-c11",
          "c11-lock-free-spsc",
          "c11-mocked-hal",
          "armv7m-bare-metal",
          "rv32-bare-metal",
          "generic-rtos",
          "embedded-linux-posix"
        ]
      }
    }
  }
}
