{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arjun7965/llm-coding-benchmark/schemas/fixture-validation-report.schema.json",
  "title": "Sandboxed fixture validation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "answerSha256",
    "targetProfile",
    "fixtureStatus",
    "startedAt",
    "finishedAt",
    "sandbox",
    "phases",
    "success"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "taskId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "answerSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "targetProfile": {
      "type": ["string", "null"],
      "enum": [
        null,
        "portable-c11",
        "c11-lock-free-spsc",
        "c11-mocked-hal",
        "armv7m-bare-metal",
        "rv32-bare-metal",
        "generic-rtos",
        "embedded-linux-posix"
      ]
    },
    "fixtureStatus": {
      "enum": ["active", "scaffold"]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "network",
        "filesystem",
        "resourceLimits"
      ],
      "properties": {
        "runtime": { "const": "bubblewrap" },
        "network": { "const": "none" },
        "filesystem": { "const": "isolated" },
        "resourceLimits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["compile", "test"],
          "properties": {
            "compile": { "$ref": "#/$defs/resourceLimits" },
            "test": { "$ref": "#/$defs/resourceLimits" }
          }
        }
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/phase" }
    },
    "success": { "type": "boolean" }
  },
  "$defs": {
    "resourceLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "addressSpaceBytes",
        "cpuSeconds",
        "fileBytes",
        "openFiles"
      ],
      "properties": {
        "addressSpaceBytes": { "type": "integer", "minimum": 1 },
        "cpuSeconds": { "type": "integer", "minimum": 1 },
        "fileBytes": { "type": "integer", "minimum": 1 },
        "openFiles": { "type": "integer", "minimum": 1 }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "phase",
        "argv",
        "timeoutMs",
        "startedAt",
        "finishedAt",
        "durationMs",
        "exitCode",
        "signal",
        "timedOut",
        "stdout",
        "stderr",
        "error"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "phase": { "enum": ["compile", "test"] },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "startedAt": { "type": "string", "format": "date-time" },
        "finishedAt": { "type": "string", "format": "date-time" },
        "durationMs": { "type": "integer", "minimum": 0 },
        "exitCode": { "type": ["integer", "null"] },
        "signal": { "type": ["string", "null"] },
        "timedOut": { "type": "boolean" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "error": { "type": ["string", "null"] }
      }
    }
  }
}
