{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arjun7965/llm-firmware-benchmark/schemas/fixture-validation-report.schema.json",
  "title": "Sandboxed fixture validation report",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "suite": { "const": "firmware" }
        },
        "required": ["suite"]
      },
      "then": {
        "properties": {
          "targetProfile": { "type": "string" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "suite": { "const": "auxiliary" }
        },
        "required": ["suite"]
      },
      "then": {
        "properties": {
          "targetProfile": { "const": null }
        }
      }
    }
  ],
  "required": [
    "schemaVersion",
    "taskId",
    "answerSha256",
    "suite",
    "targetProfile",
    "validationProfile",
    "validationProfileRevision",
    "validationProfileSha256",
    "validationEnvironment",
    "fixtureStatus",
    "language",
    "startedAt",
    "finishedAt",
    "sandbox",
    "toolchains",
    "artifacts",
    "phases",
    "success"
  ],
  "properties": {
    "schemaVersion": { "const": "1.5" },
    "taskId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "answerSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "suite": {
      "enum": ["firmware", "auxiliary"]
    },
    "targetProfile": {
      "type": ["string", "null"],
      "enum": [
        null,
        "portable-c11",
        "c11-lock-free-spsc",
        "c11-mocked-hal",
        "armv7m-bare-metal",
        "rv32-bare-metal",
        "generic-rtos",
        "embedded-linux-posix"
      ]
    },
    "validationProfile": {
      "enum": [
        "c11-host",
        "go-std",
        "node-typescript",
        "node-typescript-postgresql",
        "postgresql",
        "python3-pytest-hypothesis",
        "python3-stdlib",
        "react18-typescript",
        "stable-rust"
      ]
    },
    "validationProfileRevision": {
      "type": "integer",
      "minimum": 1
    },
    "validationProfileSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "validationEnvironment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "sha256",
        "host",
        "execution"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "host": {
          "type": "object",
          "additionalProperties": false,
          "required": ["operatingSystem", "release", "architecture"],
          "properties": {
            "operatingSystem": {
              "type": "string",
              "pattern": "^[a-z0-9._-]+$"
            },
            "release": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._-]+$"
            },
            "architecture": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._-]+$"
            }
          }
        },
        "execution": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": {
                "kind": { "const": "host" }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "image"],
              "properties": {
                "kind": { "const": "oci" },
                "image": {
                  "type": "string",
                  "pattern": "^[a-z0-9./_-]+(?::[A-Za-z0-9._-]+)?@sha256:[a-f0-9]{64}$"
                }
              }
            }
          ]
        }
      }
    },
    "fixtureStatus": {
      "enum": ["active", "scaffold"]
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9+._-]*$"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "runtimeVersion",
        "limiter",
        "limiterVersion",
        "network",
        "filesystem",
        "resourceLimits"
      ],
      "properties": {
        "runtime": { "const": "bubblewrap" },
        "runtimeVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "limiter": { "const": "prlimit" },
        "limiterVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "network": { "const": "none" },
        "filesystem": { "const": "isolated" },
        "resourceLimits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["compile", "test"],
          "properties": {
            "compile": { "$ref": "#/$defs/resourceLimits" },
            "test": { "$ref": "#/$defs/resourceLimits" }
          }
        }
      }
    },
    "toolchains": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/toolchain" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/phase" }
    },
    "success": { "type": "boolean" }
  },
  "$defs": {
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "executable", "version", "versionArgv"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9+._-]*$"
        },
        "executable": {
          "type": "string",
          "pattern": "^/usr/"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "versionArgv": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sizeBytes"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^build/[A-Za-z0-9._/-]+$"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "resourceLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "addressSpaceBytes",
        "cpuSeconds",
        "fileBytes",
        "openFiles"
      ],
      "properties": {
        "addressSpaceBytes": { "type": "integer", "minimum": 1 },
        "cpuSeconds": { "type": "integer", "minimum": 1 },
        "fileBytes": { "type": "integer", "minimum": 1 },
        "openFiles": { "type": "integer", "minimum": 1 }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "phase",
        "argv",
        "outcome",
        "timeoutMs",
        "startedAt",
        "finishedAt",
        "durationMs",
        "exitCode",
        "signal",
        "timedOut",
        "stdout",
        "stderr",
        "error"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "phase": { "enum": ["compile", "test"] },
        "outcome": {
          "enum": ["error", "failed", "passed", "timed-out"]
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "startedAt": { "type": "string", "format": "date-time" },
        "finishedAt": { "type": "string", "format": "date-time" },
        "durationMs": { "type": "integer", "minimum": 0 },
        "exitCode": { "type": ["integer", "null"] },
        "signal": { "type": ["string", "null"] },
        "timedOut": { "type": "boolean" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "error": { "type": ["string", "null"] }
      }
    }
  }
}
