      "replace": "if (receiver->frame_length >= MODBUS_RTU_REQUEST_BYTES) {\n    return false;\n  }"
    },
    {
      "id": "invert-crc-validation",
      "description": "Accept an invalid Modbus CRC and reject the valid one.",
