{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arjun7965/llm-firmware-benchmark/schemas/repeat-scores.schema.json",
  "title": "Repeated benchmark scores",
  "type": "object",
  "required": [
    "schemaVersion",
    "rubric",
    "validationContracts",
    "tasks"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "rubric": {
      "type": "string",
      "minLength": 1
    },
    "validationContracts": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/validationContract"
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    }
  },
  "patternProperties": {
    "^(?!rubric$|schemaVersion$|tasks$|validationContracts$)[a-z0-9]+(?:[._-][a-z0-9]+)*$": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^run[1-9][0-9]*$"
      },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "contractReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision", "sha256"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "validationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "environment"],
      "properties": {
        "profile": {
          "$ref": "#/$defs/contractReference"
        },
        "environment": {
          "$ref": "#/$defs/contractReference"
        }
      }
    }
  }
}
