{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fixture Mutation Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "mutations"],
  "properties": {
    "schemaVersion": {
      "const": "1.3"
    },
    "source": {
      "type": "string",
      "pattern": "^reference/[A-Za-z0-9._/-]+$"
    },
    "answerSource": {
      "type": "string",
      "pattern": "^reference/[A-Za-z0-9._/-]+$"
    },
    "stagedPath": {
      "type": "string",
      "pattern": "^(?:starter|mocks)/[A-Za-z0-9._/-]+$"
    },
    "mutations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "find",
          "replace"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "find": {
            "type": "string",
            "minLength": 1
          },
          "replace": {
            "type": "string"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "required": ["answerSource"] },
      "then": { "required": ["stagedPath"] }
    },
    {
      "if": { "required": ["stagedPath"] },
      "then": { "required": ["answerSource"] }
    }
  ]
}
