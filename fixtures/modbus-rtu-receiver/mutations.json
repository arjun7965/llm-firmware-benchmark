{
  "schemaVersion": "1.3",
  "source": "reference/modbus_rtu_receiver.c",
  "mutations": [
    {
      "id": "delay-silence-deadline",
      "description": "Require one tick more than the documented RTU silence interval.",
      "find": "if (elapsed < MODBUS_RTU_SILENCE_TICKS) {",
      "replace": "if (elapsed <= MODBUS_RTU_SILENCE_TICKS) {"
    },
    {
      "id": "drop-oversize-terminal-result",
